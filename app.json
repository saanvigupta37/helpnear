{
  "expo": {
    "name": "HelpNear",
    "slug": "helpnear",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "helpnear",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.helpnear.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HelpNear needs your location to find helpers nearby.",
        "NSLocationAlwaysUsageDescription": "HelpNear needs your location to keep you safe during active tasks.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "HelpNear needs your location to find helpers nearby and keep you safe."
      },
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_IOS_API_KEY"
      }
    },
    "android": {
      "package": "com.helpnear.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CALL_PHONE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_ANDROID_API_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "HelpNear needs location access to connect you with nearby helpers.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}